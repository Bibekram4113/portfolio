# Auto normalize line endings for all text files
* text=auto

# HTML
*.html text eol=lf
*.htm text eol=lf

# CSS & Stylesheets
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf

# JavaScript & TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# JSON
*.json text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary

# Documentation
*.md text eol=lf
README.md text eol=lf
